---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "IA Infra Latino | IA + Infraestructura + Automatización",
  description = "IA Infra Latino: IA, infraestructura y automatización para ingenieros modernos que quieren construir sistemas, autoridad técnica y productos digitales.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="IA para ingenieros, infraestructura, data center, network engineering, automatización, DevOps, productos digitales técnicos" />
    <meta name="author" content="Jose Roberto De Leon" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="canonical" href="https://iainfralatino.com/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://iainfralatino.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_US" />
    <meta property="og:image" content="https://iainfralatino.com/assets/img/og-cover.webp" />
    <meta property="og:image:width" content="1376" />
    <meta property="og:image:height" content="768" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://iainfralatino.com/assets/img/og-cover.webp" />
  </head>
  <body>
    <div class="background-grid"></div>
    <header class="site-header">
      <nav class="nav container">
        <a class="brand" href="/#top" aria-label="IA Infra Latino Home">
          <span class="brand-mark">IA</span>
          <span>Infra Latino</span>
        </a>
        <button class="nav-toggle" aria-label="Abrir menú" aria-expanded="false">☰</button>
        <div class="nav-links" data-nav-links>
          <a href="#top">Inicio</a>
          <a href="#leadmagnet">Recursos</a>
        </div>
      </nav>
    </header>

    <slot />

    <footer class="footer container">
      <div class="footer-top">
        <a class="brand" href="/#top"><span class="brand-mark">IA</span><span>Infra Latino</span></a>
        <div class="footer-links">
          <a href="https://www.instagram.com/iainfralatino/" target="_blank" rel="noopener">Instagram</a>
          <a href="https://www.facebook.com/iainfralatino" target="_blank" rel="noopener">Facebook</a>
          <a href="https://www.tiktok.com/@iainfralatino" target="_blank" rel="noopener">TikTok</a>
          <a href="https://www.youtube.com/@IAInfraLatino" target="_blank" rel="noopener">YouTube</a>
        </div>
      </div>
      <p class="footer-firma">Jose Roberto | IA Infra Latino<sup>™</sup></p>
    </footer>

    <script is:inline src="/assets/js/main.js"></script>
  </body>
</html>
